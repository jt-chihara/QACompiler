{
  "name": "qa-compiler",
  "version": "0.1.0",
  "description": "AI-driven QA process engine that executes risk analysis, test planning, test analysis, and test design via structured YAML workflows",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "qa-compiler": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "qa",
    "testing",
    "ai",
    "workflow",
    "yaml",
    "dag"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@ai-sdk/openai": "^3.0.30",
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "ai": "^6.0.97",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
